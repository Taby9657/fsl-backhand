# Database (Railway PostgreSQL)
DATABASE_URL="postgresql://user:password@host:5432/fsl_db"

# JWT
JWT_SECRET="your-super-secret-jwt-key-min-32-chars"
JWT_EXPIRES_IN="30d"

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Apple Sign In
APPLE_CLIENT_ID="com.yourapp.fsl"
APPLE_TEAM_ID="ABCD1234EF"
APPLE_KEY_ID="ABCD1234EF"
APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# Cloudinary (foto / loga)
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# Stripe (platby)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# App
PORT=3000
CLIENT_URL="https://fsl.app"
NODE_ENV="production"

# Supervisor (comma-separated User IDs se supervisor přístupem)
SUPERVISOR_USER_IDS="user-mv"

# Fio Banka – párování bankovních převodů
# Vygeneruj token na: https://www.fio.cz → Internetbanking → API
FIO_API_TOKEN="your-fio-api-token"

# Bankovní účet pro QR platby (SPAYD formát)
BANK_IBAN="CZ6508000000192000145399"
BANK_BIC="GIBACZPX"
